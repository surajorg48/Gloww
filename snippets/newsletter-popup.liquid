{% comment %}
  Newsletter Popup — Glowwmint
  Displays once per session. Uses localStorage to avoid repeat displays.
{% endcomment %}

<div id="gloww-newsletter-popup" class="gloww-popup-overlay" style="display:none;">
  <div class="gloww-popup-container">
    <button class="gloww-popup-close" aria-label="Close popup" onclick="document.getElementById('gloww-newsletter-popup').style.display='none';sessionStorage.setItem('gloww-popup-shown','true');">&times;</button>
    
    <div class="gloww-popup-content">
      <div class="gloww-popup-icon">🌿</div>
      <h3 class="gloww-popup-title">Join the Glow!</h3>
      <p class="gloww-popup-text">Get exclusive deals, new arrivals & beauty tips straight to your inbox.</p>
      
      {% form 'customer', id: 'gloww-newsletter-form' %}
        <div class="gloww-popup-form">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input 
            type="email" 
            name="contact[email]" 
            placeholder="Enter your email" 
            required 
            class="gloww-popup-input"
            aria-label="Email address"
          >
          <button type="submit" class="gloww-popup-btn button">Subscribe</button>
        </div>
      {% endform %}
      
      <p class="gloww-popup-disclaimer">No spam, ever. Unsubscribe anytime.</p>
    </div>
  </div>
</div>

<style>
  .gloww-popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  
  .gloww-popup-container {
    background: #fff;
    border-radius: 16px;
    max-width: 440px;
    width: 90%;
    padding: 48px 32px 40px;
    position: relative;
    box-shadow: 0 24px 64px rgba(0,0,0,0.2);
    text-align: center;
  }
  
  .gloww-popup-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: #999;
    padding: 4px 8px;
    line-height: 1;
  }
  
  .gloww-popup-close:hover {
    color: #333;
  }
  
  .gloww-popup-icon {
    font-size: 40px;
    margin-bottom: 8px;
  }
  
  .gloww-popup-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 8px;
    color: #1a1a1a;
  }
  
  .gloww-popup-text {
    font-size: 0.95rem;
    color: #555;
    margin: 0 0 24px;
    line-height: 1.5;
  }
  
  .gloww-popup-form {
    display: flex;
    gap: 8px;
  }
  
  .gloww-popup-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid #ddd;
    border-radius: 10px;
    font-size: 0.9375rem;
    outline: none;
  }
  
  .gloww-popup-input:focus {
    border-color: #2ECC71;
    box-shadow: 0 0 0 3px rgba(46,204,113,0.1);
  }
  
  .gloww-popup-btn {
    padding: 12px 20px;
    white-space: nowrap;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 10px;
    cursor: pointer;
  }
  
  .gloww-popup-disclaimer {
    font-size: 0.75rem;
    color: #999;
    margin: 16px 0 0;
  }

  @media screen and (max-width: 480px) {
    .gloww-popup-container {
      padding: 40px 24px 32px;
    }
    
    .gloww-popup-form {
      flex-direction: column;
    }
    
    .gloww-popup-btn {
      width: 100%;
    }
  }
</style>

<script>
  (function() {
    if (sessionStorage.getItem('gloww-popup-shown')) return;
    setTimeout(function() {
      var popup = document.getElementById('gloww-newsletter-popup');
      if (popup) {
        popup.style.display = 'flex';
      }
    }, 5000);
  })();
</script>
