<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=5">
<meta name="view-transition" content="same-origin">
<meta name="theme-color" content="#165230">
<meta name="msapplication-TileColor" content="#165230">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="format-detection" content="telephone=no">
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">

{%- comment -%} Preconnect to critical third-party origins {%- endcomment -%}
<link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
<link rel="dns-prefetch" href="https://cdn.shopify.com">

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign seo_description = page_description | default: shop.description | default: 'Glowwmint — Premium Beauty & Wellness Products. Shop skincare, health essentials, and self-care products with free shipping and COD across India.'

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
-%}

{%- comment -%} Open Graph Tags {%- endcomment -%}
<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
<meta property="og:locale" content="{{ request.locale.iso_code | replace: '-', '_' }}">

{%- if page_image -%}
  <meta property="og:image" content="http:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
  <meta property="og:image:alt" content="{{ og_title | escape }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
  <meta property="product:availability" content="{% if product.available %}in stock{% else %}out of stock{% endif %}">
  <meta property="product:condition" content="new">
  <meta property="product:brand" content="{{ product.vendor | escape }}">
{%- endif -%}

{%- comment -%} Twitter Card Tags {%- endcomment -%}
{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if page_image -%}
  <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200 }}">
  <meta name="twitter:image:alt" content="{{ og_title | escape }}">
{%- endif -%}

{%- comment -%} Page Title {%- endcomment -%}
<title>
  {{ page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>

<link rel="canonical" href="{{ canonical_url }}">

{%- comment -%} Meta Description {%- endcomment -%}
<meta name="description" content="{{ seo_description | escape }}">

{%- comment -%} Structured Data — Organization {%- endcomment -%}
{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "{{ shop.name | escape }}",
  "url": "{{ request.origin }}",
  "logo": "{{ settings.logo | image_url: width: 600 }}",
  "description": "{{ shop.description | escape }}",
  "sameAs": [
    "https://www.instagram.com/glowwmint",
    "https://www.facebook.com/"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": "English"
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "{{ shop.name | escape }}",
  "url": "{{ request.origin }}",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "{{ request.origin }}/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
{%- endif -%}

{%- comment -%} Structured Data — Product {%- endcomment -%}
{%- if request.page_type == 'product' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.title | escape }}",
  "description": "{{ product.description | strip_html | truncate: 200 | escape }}",
  "url": "{{ canonical_url }}",
  "brand": {
    "@type": "Brand",
    "name": "{{ product.vendor | escape }}"
  },
  {%- if product.featured_image -%}
  "image": "https:{{ product.featured_image | image_url: width: 1200 }}",
  {%- endif -%}
  "offers": {
    "@type": "Offer",
    "price": "{{ product.price | money_without_currency | strip_html }}",
    "priceCurrency": "{{ cart.currency.iso_code }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "url": "{{ canonical_url }}"
  }
}
</script>
{%- endif -%}

{%- comment -%} Structured Data — BreadcrumbList {%- endcomment -%}
{%- if request.page_type == 'product' or request.page_type == 'collection' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ request.origin }}"
    }
    {%- if request.page_type == 'collection' -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "{{ collection.title | escape }}",
      "item": "{{ canonical_url }}"
    }
    {%- endif -%}
    {%- if request.page_type == 'product' -%}
    {%- if product.collections.size > 0 -%}
    ,{
      "@type": "ListItem",
      "position": 2,
      "name": "{{ product.collections.first.title | escape }}",
      "item": "{{ product.collections.first.url | prepend: request.origin }}"
    }
    {%- endif -%}
    ,{
      "@type": "ListItem",
      "position": 3,
      "name": "{{ product.title | escape }}",
      "item": "{{ canonical_url }}"
    }
    {%- endif -%}
  ]
}
</script>
{%- endif -%}

{%- comment -%} Structured Data — FAQ (for homepage) {%- endcomment -%}
{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What payment methods do you accept?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We accept Cash on Delivery (COD) for all orders."
      }
    },
    {
      "@type": "Question",
      "name": "Do you ship across India?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, we deliver to most locations across India."
      }
    },
    {
      "@type": "Question",
      "name": "When will I get my order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Orders are usually processed within 1–2 business days and delivered within 3–7 business days, depending on your location."
      }
    },
    {
      "@type": "Question",
      "name": "Are your products genuine?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Absolutely. Every product we sell is sourced from trusted suppliers and undergoes quality checks to ensure authenticity and safety."
      }
    },
    {
      "@type": "Question",
      "name": "How can I track my order?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Once your order ships, you'll receive an email or SMS with a tracking link so you can follow your package in real-time."
      }
    }
  ]
}
</script>
{%- endif -%}
