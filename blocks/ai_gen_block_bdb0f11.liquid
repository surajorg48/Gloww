{% doc %}
  @prompt
    Horizontal Ticker, adjust it with site make sure its fit in site fully from left and right side, increase speed a little bit, and replace all the texts with these: 🎁 Grab Exclusive Deals Before They’re Gone!, ✨ Flat 30% OFF on Bestsellers – For 24 hours Only!, 🚚 Free Shipping

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ticker-container-{{ ai_gen_id }} {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px 0;
    border-top: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
  }

.ai-ticker-wrapper-{{ ai_gen_id }} {
  display: flex;
  width: fit-content;
  animation: ai-ticker-scroll-{{ ai_gen_id }} {{ block.settings.speed }}s linear infinite;
  white-space: nowrap;
  will-change: transform;
}


  .ai-ticker-content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .ai-ticker-item-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    padding: 0 {{ block.settings.item_spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-transform: {{ block.settings.text_transform }};
    white-space: nowrap;
  }

  .ai-ticker-separator-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    color: {{ block.settings.separator_color }};
    font-size: {{ block.settings.font_size }}px;
    padding: 0 {{ block.settings.separator_spacing }}px;
  }

  @keyframes ai-ticker-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-100%);
    }
  }

  {% if block.settings.pause_on_hover %}
    .ai-ticker-wrapper-{{ ai_gen_id }}:hover {
      animation-play-state: paused;
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-ticker-item-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: 0 {{ block.settings.item_spacing | times: 0.8 }}px;
    }
    
    .ai-ticker-separator-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
      padding: 0 {{ block.settings.separator_spacing | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-ticker-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ticker-wrapper-{{ ai_gen_id }}">
    <div class="ai-ticker-content-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% assign text_key = 'ticker_text_' | append: i %}
        {% assign ticker_text = block.settings[text_key] %}
        {% if ticker_text != blank %}
          <span class="ai-ticker-item-{{ ai_gen_id }}">{{ ticker_text }}</span>
          {% unless forloop.last %}
            <span class="ai-ticker-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          {% endunless %}
        {% endif %}
      {% endfor %}
    </div>
    
    <div class="ai-ticker-content-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% assign text_key = 'ticker_text_' | append: i %}
        {% assign ticker_text = block.settings[text_key] %}
        {% if ticker_text != blank %}
          <span class="ai-ticker-item-{{ ai_gen_id }}">{{ ticker_text }}</span>
          {% unless forloop.last %}
            <span class="ai-ticker-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
          {% endunless %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Horizontal ticker",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "ticker_text_1",
      "label": "Ticker text 1",
      "default": "🎁 Grab Exclusive Deals Before They're Gone!"
    },
    {
      "type": "text",
      "id": "ticker_text_2",
      "label": "Ticker text 2",
      "default": "✨ Flat 30% OFF on Bestsellers – For 24 hours Only!"
    },
    {
      "type": "text",
      "id": "ticker_text_3",
      "label": "Ticker text 3",
      "default": "🚚 Free Shipping"
    },
    {
      "type": "text",
      "id": "ticker_text_4",
      "label": "Ticker text 4"
    },
    {
      "type": "text",
      "id": "ticker_text_5",
      "label": "Ticker text 5"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "•"
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
